# 应用基础配置
APP_NAME=chat-agent-backend
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=chat_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# RAGFlow 配置
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=your-ragflow-api-key-here

# OpenAI 兼容模型配置
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Planner 配置
PLANNER_USE_LLM=false
PLANNER_MODEL=

# 知识库配置
# 指定默认使用的知识库数据集 ID，避免混用不同 embedding model 的数据集
# 留空则使用所有启用的知识库（可能触发 embedding model 不兼容错误）
DEFAULT_KNOWLEDGE_DATASET_ID=

# MCP 服务配置（可选，单行 JSON 格式）
# 高德 streamable_http 示例：
# MCP_SERVERS_JSON={"mcpServers":{"amap-maps-streamableHTTP":{"url":"https://mcp.amap.com/mcp?key=replace-me"}}}
# 
# SSE 示例：
# MCP_SERVERS_JSON={"mcpServers":{"demo-sse":{"transport":"sse","url":"https://mcp.example.com/sse"}}}
# 
# stdio 示例：
# MCP_SERVERS_JSON=[{"name":"amap","transport":"stdio","command":"uvx","args":["amap-mcp-server"],"env":{"AMAP_MAPS_API_KEY":"replace-me"}}]
MCP_SERVERS_JSON=