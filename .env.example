APP_NAME=chat-agent-backend
APP_ENV=local
APP_HOST=0.0.0.0
# docker容器端口
APP_PORT=8000
# 宿主机端口
APP_HOST_PORT=8000

# 日志文件是否写入文件
LOG_TO_FILE=true
# 日志目录
LOG_DIR=logs
# 日志文件名
LOG_FILE_NAME=chat-agent.log
# 日志文件轮转时间
LOG_ROTATE_WHEN=midnight
# 日志文件轮转间隔
LOG_ROTATE_INTERVAL=1
# 日志文件保留天数
LOG_BACKUP_COUNT=14

# 数据库
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_HOST_PORT=55432
POSTGRES_DB=chat_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DSN=

# redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6379

# 知识库服务
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=replace-me
DEFAULT_KNOWLEDGE_DATASET_ID=

# 路况接口
LIVE_AGENT_BASE_URL=http://localhost:8081
LIVE_AGENT_TIMEOUT_SECONDS=15
# 开发环境需要借助 terminal_exec 访问监控网接口时再开启。
LIVE_AGENT_TERMINAL_EXEC_ENABLED=false
LIVE_AGENT_TERMINAL_EXEC_URL=https://frp-sea.com:28965/api/v1/mcp/terminal_exec
LIVE_AGENT_TERMINAL_TARGET_BASE_URL=http://33.69.9.33:8081
LIVE_AGENT_TERMINAL_EXEC_TIMEOUT_SECONDS=180
LIVE_AGENT_TERMINAL_EXEC_RETRIES=3
LIVE_AGENT_TERMINAL_EXEC_CURL_BINARY=curl

# MCP_SERVERS_JSON 支持 stdio、http、streamable_http 和 sse。
# .env 中请使用单行 JSON；不要直接粘贴未加引号的多行 JSON。
# 高德文档常见格式示例：
# MCP_SERVERS_JSON={"mcpServers":{"amap-maps-streamableHTTP":{"url":"https://mcp.amap.com/mcp?key=replace-me"}}}
# SSE 示例：
# MCP_SERVERS_JSON={"mcpServers":{"demo-sse":{"transport":"sse","url":"https://mcp.example.com/sse"}}}
# stdio 示例：
# MCP_SERVERS_JSON=[{"name":"amap","transport":"stdio","command":"uvx","args":["amap-mcp-server"],"env":{"AMAP_MAPS_API_KEY":"replace-me"}}]
MCP_SERVERS_JSON=[]

# 大模型配置 需要openai 兼容格式
OPENAI_BASE_URL=
OPENAI_API_KEY=replace-me
# 大模型接口请求超时时间
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MODEL=gpt-4.1-mini
# 大模型是否启用思考
OPENAI_ENABLE_THINKING=
# 分类模型
PLANNER_MODEL=
PLANNER_BASE_URL=
PLANNER_API_KEY=
PLANNER_ENABLE_THINKING=

# 模型服务超时时间
PLANNER_TIMEOUT_SECONDS=
# 知识库服务超时时间
RAGFLOW_TIMEOUT_SECONDS=15
# mcp服务超时
MCP_HTTP_TIMEOUT_SECONDS=10
MCP_SSE_TIMEOUT_SECONDS=10
MCP_SSE_READ_TIMEOUT_SECONDS=60
