APP_NAME=chat-agent-backend
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_HOST_PORT=8090

# 日志
LOG_TO_FILE=true
LOG_DIR=logs
LOG_FILE_NAME=chat-agent.log
LOG_ROTATE_WHEN=midnight
LOG_ROTATE_INTERVAL=1
LOG_BACKUP_COUNT=14

# 数据库
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_HOST_PORT=55432
POSTGRES_DB=chat_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DSN=

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST_PORT=6379

# 知识库
RAGFLOW_BASE_URL=http://host.docker.internal:8008
RAGFLOW_API_KEY=ragflow-He4c0XmA3c52-O5DNg9Jup2XM0TrDO_vO_zKSfDAxzc
DEFAULT_KNOWLEDGE_DATASET_ID=a2e9f8ff324011f198edce511781c013

# 路况、路线、服务区、路网接口
LIVE_AGENT_BASE_URL=http://host.docker.internal:8081
LIVE_AGENT_TIMEOUT_SECONDS=15
ENABLE_MONITOR_NETWORK_PROXY=false
USE_BRIDGE_PROXY_IN_DEV=true
LIVE_AGENT_TERMINAL_EXEC_ENABLED=false
LIVE_AGENT_TERMINAL_EXEC_URL=https://frp-sea.com:28965/api/v1/mcp/terminal_exec
LIVE_AGENT_TERMINAL_TARGET_BASE_URL=http://33.69.9.33:8081
LIVE_AGENT_TERMINAL_EXEC_TIMEOUT_SECONDS=180
LIVE_AGENT_TERMINAL_EXEC_RETRIES=3
LIVE_AGENT_TERMINAL_EXEC_CURL_BINARY=curl

# MCP
MCP_SERVERS_JSON=[]

# 大模型配置（使用你的本地 OpenAI 兼容接口）
OPENAI_BASE_URL=http://172.19.16.4:8080/v1
OPENAI_API_KEY=sk-fb528ed72b9e48c0b879eb096e4e2be5
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MODEL=Qwen/Qwen3.5-27B
OPENAI_ENABLE_THINKING=false

# Planner 模型，默认与主模型一致
PLANNER_MODEL=Qwen/Qwen3.5-27B
PLANNER_BASE_URL=http://172.19.16.4:8080/v1
PLANNER_API_KEY=sk-fb528ed72b9e48c0b879eb096e4e2be5
PLANNER_ENABLE_THINKING=false
PLANNER_TIMEOUT_SECONDS=60

# 其他超时
RAGFLOW_TIMEOUT_SECONDS=15
MCP_HTTP_TIMEOUT_SECONDS=10
MCP_SSE_TIMEOUT_SECONDS=10
MCP_SSE_READ_TIMEOUT_SECONDS=60
